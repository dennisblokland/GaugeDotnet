<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-dennisblokland" value="https://nuget.pkg.github.com/dennisblokland/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="github-dennisblokland">
      <package pattern="VaettirNet.Btleplug" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
